; ********************************************************************************************************************************************************
;***          agentB.NLS  (contains all the code for the agentB)                                                                                    ****
;*********************************************************************************************************************************************************
; DESCRIPTION OF THE AGENT
; - A follower agent that reacts to nearby influencers in a social media ecosystem
; - If inside an influencer's radius, it adopts that influencer as its current favorite (following)
; - It moves toward its favorite influencer and copies that influencer's color
; - During influencer conflict, it may be "stolen" by another influencer depending on attack force vs loyalty
; - Loyalty is modeled through resistance, which depends on the reputation of the followed influencer
; - Resistance is capped to avoid unrealistic immunity
;
;*********************************************************************************************************************************************************
;*********************************************************************************************************************************************************
; LOGBOOK OF UPDATES IN THIS FILE
; --Date--- |-----Description--------------------------------------------------------------------------------|---Person(s)-------------------------------
; 20250423    Initial template of a dummy-breed to be adapted by the project group                               Gion
; 20260413    
;
;
;********************end logbook ************************************************************************************************************************
;*********************************************************************************************************************************************************
; LOCAL VARIABLES

agentBs-own [
    following  ; current favorite influencer 
    resistance ; loyalty strength against being stolen
    state      ; current reactive state
    loyaltyTimer
    switchCooldown
]


;******************* end local variables *****************************************************************************************************************
;**********************************************************************************************************************************************************
; SETUP FUNCTIONS
to setup-agentBs

  create-agentBs Number_AgentB  [
    setxy random-xcor random-ycor
    set shape "person"
    set size 0.5
    set following nobody
    set resistance base-resistance
    set state "state_wander"
    set loyaltyTimer 0
    set switchCooldown 0
    update-follower-color
  ]
  
end ;setup-agentBs

;**********************************************************************************************************************************************************
; UPDATE ENVIRONMENT INFORMATION (required by main model loop)

to updateEnvironmentInfo_agentBs
  ; Placeholder for compatibility with main loop
end

;***************************end environment update ********************************************************************************************************
;**********************************************************************************************************************************************************
; REACTIVE DECISION HIERARCHY

to reactive_agentBs
  update-state_agentB

  if state = "state_wander" [
    state_wander
    stop
  ]

  if state = "state_follow" [
    state_follow
    stop
  ]

  if state = "state_defend-loyalty" [
    state_defend-loyalty
    stop
  ]
end

;***************************end reactive hierarchy ********************************************************************************************************

;**********************************************************************************************************************************************************
; STATE UPDATE
to update-state_agentB
  if switchCooldown > 0 [
    set switchCooldown switchCooldown - 1
  ]
  
  if following = nobody [
    try-adopt-influencer
    if following = nobody [
      set state "state_wander"
      stop
    ]
  ]

  if [conflictActive] of following [
    set state "state_defend-loyalty"
    stop
  ]

  set state "state_follow"
end


;***************************end state update **************************************************************************************************************
;**********************************************************************************************************************************************************
; FINITE STATE MACHINE

to state_wander
  update-follower-color
  rt random 50 - random 50
  fd speed
  bounce-at-boundary
  try-adopt-influencer
end

to state_follow
  set loyaltyTimer loyaltyTimer + 1
  update-resistance
  update-follower-color

  ; re-evaluate more often so influencer counts can change
  if ticks mod 20 = 0 and loyaltyTimer > 15 [
  reevaluate-influencer-choice
  ]

  ; small exploration only for weakly committed followers
  if loyaltyTimer < 20 and switchCooldown = 0 and random-float 1 < 0.002 [
    let current-following following
    let alt one-of agentAs with [self != current-following]
    if alt != nobody [
      set following alt
      set loyaltyTimer 0
      set switchCooldown 25
  ]
]

  ; if follower drifts too far from current influencer, it may detach
  if following != nobody [
    if distance following > ([engagementRadius] of following * 1.75) [
      if loyaltyTimer < 15 and random-float 1 < 0.08 [
        set following nobody
        set loyaltyTimer 0
        set switchCooldown 10
        set state "state_wander"
        stop
    ]
  ]
]

  if following != nobody [
    face following
    fd speed
    bounce-at-boundary
  ]
end

to state_defend-loyalty
  set loyaltyTimer loyaltyTimer + 1
  update-resistance
  update-follower-color

  let attacker get-attacker-for following

  if attacker != nobody and following != nobody [
    let attack-force compute-attack-force attacker
    let hold-force compute-hold-force following

    if attack-force > hold-force [
      set following attacker
      set loyaltyTimer 0
      set switchCooldown 20
    ]
  ]

  if following = nobody [
    set state "state_wander"
  ]
  if following != nobody [
    set state "state_follow"
  ]
end


;***************************end finite state machine ******************************************************************************************************
;**********************************************************************************************************************************************************
; INFLUENCER SELECTION
to try-adopt-influencer
  let candidates agentAs with [distance myself <= engagementRadius]

  if any? candidates [
    ; pick the strongest nearby option when unattached
    let best-choice max-one-of candidates [reputation - distance myself]
    set following best-choice
    set loyaltyTimer 0
    set switchCooldown 15
    update-resistance
    update-follower-color
  ]
end

to reevaluate-influencer-choice
  if following = nobody [ stop ]
  if switchCooldown > 0 [ stop ]

  let candidates agentAs with [distance myself <= engagementRadius]
  if not any? candidates [ stop ]

  let best-choice max-one-of candidates [reputation - distance myself]
  if best-choice = following [ stop ]

  let current-score ([reputation] of following) - distance following
  let best-score ([reputation] of best-choice) - distance best-choice

  ; stronger hysteresis: followers only switch when the alternative is clearly better
  let switching-threshold 6 + (loyaltyTimer * 0.12) + (resistance * 0.05)

  if best-score > current-score + switching-threshold [
    if random-float 1 < 0.35 [
      set following best-choice
      set loyaltyTimer 0
      set switchCooldown 30
    ]
  ]
end

;***************************end influencer selection ******************************************************************************************************
;**********************************************************************************************************************************************************
; CONFLICT / STEALING SUPPORT
to-report get-attacker-for [defender-agent]
  let attackers agentAs with [self != defender-agent and conflictActive]

  if any? attackers [
    report max-one-of attackers [reputation + conflictIntensity - distance myself]
  ]

  report nobody
end

to-report compute-attack-force [attacker-agent]
  let rep [reputation] of attacker-agent
  let intensity [conflictIntensity] of attacker-agent
  let dist distance attacker-agent

  report rep + (0.35 * intensity) - (0.4 * dist)
end

to-report compute-hold-force [defender-agent]
  let rep [reputation] of defender-agent

  ; weaker hold than before so stealing can actually happen
  report rep + resistance + (loyaltyTimer * 0.05)
end

;***************************end conflict support **********************************************************************************************************
;**********************************************************************************************************************************************************
; HELP FUNCTIONS
to bounce-at-boundary
  if xcor >= max-pxcor [
    set xcor max-pxcor
    set heading (- heading)
  ]
  if xcor <= min-pxcor [
    set xcor min-pxcor
    set heading (- heading)
  ]
  if ycor >= max-pycor [
    set ycor max-pycor
    set heading (180 - heading)
  ]
  if ycor <= min-pycor [
    set ycor min-pycor
    set heading (180 - heading)
  ]
end

to update-follower-color
  ifelse following = nobody [
    set color gray
  ] [
    set color [color] of following
  ]
end

to update-resistance
  ifelse following != nobody [
    set resistance min (list max-resistance
      (base-resistance + resistance-factor * [reputation] of following))
  ] [
    set resistance base-resistance
  ]
end

;***************************end help functions ************************************************************************************************************
