; ********************************************************************************************************************************************************
;***          agentB.NLS  (Basic Follower Agent - Follows Influencers)                                                                             ****
;*********************************************************************************************************************************************************
; DESCRIPTION OF THE AGENT
; - A simple follower agent that picks an influencer (agentA) to follow
; - Moves toward the influencer to maintain engagement
; - Tests the influencer agent's engagement tracking and conflict mechanics
;
;*********************************************************************************************************************************************************
;*********************************************************************************************************************************************************
; LOGBOOK OF UPDATES IN THIS FILE
; --Date--- |-----Description--------------------------------------------------------------------------------|---Person(s)-------------------------------
; 20260410    Implemented as basic follower agent for testing influencers                                         Copilot
; 20250423    Initial template of a dummy-breed to be adapted by the project group                               Gion
;
;********************end logbook ************************************************************************************************************************
;*********************************************************************************************************************************************************
; LOCAL VARIABLES
agentBs-own [
  ; Follower state
  following              ; the influencer (agentA) this follower is currently following
  moveSpeed              ; base movement speed toward influencer
  
  ; Engagement mechanics
  loyaltyTimer           ; ticks spent with current influencer
  boredomThreshold       ; ticks before getting bored if no engagement happens
  engagementNeeds        ; how much drama/engagement this follower needs (0-100)
]
;******************* end local variables *****************************************************************************************************************
;**********************************************************************************************************************************************************
; SETUP FUNCTIONS
to setup-agentBs
  create-agentBs Number_AgentB [
    set label who
    set shape "person"
    set size 1
    set color cyan
    
    ; Start at random location
    move-to one-of patches
    
    ; Initialize follower state
    set following nobody
    set moveSpeed 0.8
    
    ; Initialize engagement mechanics
    set loyaltyTimer 0
    set boredomThreshold 30 + random 20  ; get bored after 30-50 ticks without drama
    set engagementNeeds 40 + random 60   ; 40-100: how much drama they want
  ]
end

;***************************end setup functions ******************************************************************************************************************
;************************************************************************************************************************************************************
; UPDATE BELIEFS

to updateEnvironmentInfo_agentBs
  ; Check if should switch influencers
  if following = nobody [
    ; Pick a new influencer if not following anyone
    pick-influencer
  ] [
    ; Consider switching based on boredom or better options
    let current-influencer following
    
    ; Increase loyalty timer
    set loyaltyTimer loyaltyTimer + 1
    
    ; Check if bored (no drama happening and been here too long)
    let is-bored (loyaltyTimer > boredomThreshold and [conflictActive] of current-influencer = false)
    
    ; Check for high-rep influencer (reputation > current influencer)
    let high-rep-influencer one-of agentAs with [[reputation] of self > [reputation] of current-influencer]
    
    ; Check if current influencer is in conflict (drama!)
    let drama-available (any? agentAs with [conflictActive = true])
    
    if is-bored and drama-available [
      ; Switch to an influencer having conflict
      let conflicting-influencer one-of agentAs with [conflictActive = true]
      if conflicting-influencer != nobody [
        set following conflicting-influencer
        set loyaltyTimer 0
      ]
    ] else if is-bored and high-rep-influencer != nobody and random 100 < 40 [
      ; 40% chance to switch to higher reputation if bored
      set following high-rep-influencer
      set loyaltyTimer 0
    ] else if random 1000 < 5 [
      ; 0.5% chance per tick to randomly explore a different influencer
      set following one-of agentAs
      set loyaltyTimer 0
    ]
  ]
end

;***************************end update beliefs ******************************************************************************************************************
;************************************************************************************************************************************************************
; REACTIVE SUBSUMPTION HIERARCHY

to reactive_agentBs
  ; Move toward the influencer being followed
  if following != nobody [
    move-toward-influencer
  ]
end

;***************************end reactive subsumption hierarchy ***************************************************

;**********************************************************************************************************************************************************
; MOVEMENT & DECISION LOGIC

to pick-influencer
  ; Pick a new influencer based on preferences
  let all-influencers agentAs
  if any? all-influencers [
    let high-rep-ones all-influencers with [reputation > 60]
    let conflicting-ones all-influencers with [conflictActive = true]
    
    if any? conflicting-ones and random 100 < 30 [
      ; 30% chance to follow conflict/drama if available
      set following one-of conflicting-ones
    ] else if any? high-rep-ones and random 100 < 60 [
      ; 60% chance to follow high reputation
      set following one-of high-rep-ones
    ] else [
      ; Otherwise pick randomly
      set following one-of all-influencers
    ]
    set loyaltyTimer 0
  ]
end

to move-toward-influencer
  ; Face the influencer and move toward them
  set heading towards following
  forward moveSpeed
  
  ; Check if influencer is in conflict and boost engagement speed
  if [conflictActive] of following [
    forward moveSpeed * 0.5  ; Move faster toward dramatic influencers
  ]
  
  ; Update color based on engagement
  let distance-to-influencer distance following
  ifelse distance-to-influencer < 15 [
    ifelse [conflictActive] of following [
      set color orange   ; engaged AND influencer in conflict = drama!
    ] [
      set color green    ; engaged to influencer
    ]
  ] [
    set color cyan       ; searching/moving toward influencer
  ]
end

;***************************end movement ************************************************************

;*****************************************************************************************************************************************************
; HELP FUNCTIONS

;***************************end help functions ***************************************************************************************************
;*****************************************************************************************************************************************************

