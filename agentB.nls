; ********************************************************************************************************************************************************
;***          agentB.NLS  (contains all the code for the agentB)                                                                                    ****
;*********************************************************************************************************************************************************
; DESCRIPTION OF THE AGENT
; - Lives in one of the houses upon creation.
; - Moves around freely without a specific purpose
; - It checks if it might be followed by other agents by looking behind its back.
; - If it believes that it is being followed, it stops and waits to see if the same agent remains close by.
; - If that is the case it identifies the other agent as stalker and tries to escape by running to the sanctuary place.
; - Once within sanctuary, it moves around there without leaving sanctuary.
;
;*********************************************************************************************************************************************************
;*********************************************************************************************************************************************************
; LOGBOOK OF UPDATES IN THIS FILE
; --Date--- |-----Description--------------------------------------------------------------------------------|---Person(s)-------------------------------
; 20250423    Initial template of a dummy-breed to be adapted by the project group                               Gion
;
;
;
;********************end logbook ************************************************************************************************************************
;*********************************************************************************************************************************************************
; LOCAL VARIABLES
agentBs-own [
  ; finite state machine
  state;-------------state variable that corresponds to procedure names
  countTicks
  follower
  oldFollower
  identNr
  nr
  homeLoc;------------home location, where the agent lives
  localxy;------------current local patch on which the agent is standing on
  friendList;---------List of other citizen agents that are considered as friends
  friend;-------------An agent from the friendList
  agTimer1;---------- local timer for agents
  agAlarm1
]
;******************* end local variables *****************************************************************************************************************
;**********************************************************************************************************************************************************
; SETUP FUNCTIONS
to setup-agentBs
  ; example of create-agent-function, replace with your own code!
  create-agentBs Number_AgentB [;Number_AgentA from slider
    set label who
    set shape "person" 
    set size 1
    set color yellow
    move-to one-of patches with [region = "house"]
    ; save the home location
    set homeLoc patch-here
    set agAlarm1 0
    set follower []
    set oldFollower []
    set countTicks 0
    set identNr 0
    set state "State_MoveAround"
    set nr 0
  ]
 
end ;setup-agentBs

;---- specific setup functions, ; add your own code!

;***************************end setup functions ******************************************************************************************************************
;************************************************************************************************************************************************************
; UPDATE BELIEFS

to updateEnvironmentInfo_agentBs
  ; add your own code here instead
  
  ;--- save local position
  set localxy patch-here
  

end ;updateEnvironmentInfo_agentBs
;***************************end update beliefs ******************************************************************************************************************
;************************************************************************************************************************************************************
; REACTIVE SUBSUMPTION HIERARCHY
to reactive_agentBs
  ; add your own code here instead
  moveAround_agentB
end ;reactive_agentBs

;---- specific reactive intention functions
to moveAround_agentB
  rt random 50
  lt random 50
  fd 1
end

;***************************end reactive subsumption hierarchy ***************************************************************************************************
;************************************************************************************************************************************************************


; Finite State Machine
; States:
;   State_MoveAround: --------
;   State_IdentifyFollower:---
;   State_Escape:-------------
;   State_Sanctuary:----------

to State_MoveAround
  set color yellow
  ; moving around randomly, on empty patches
  rt random 50
  lt random 50
  fd 1
  ; make sure the agent moves to empty region within its neighborhood
  if not (region = "empty") 
  [
    let footstep neighborhood with [region = "empty"] 
    if any? footstep [move-to one-of footstep]
  ]
  
  ; look for indication to be followed
  ; if only one other agent is nearby and it is the same agent that is still nearby 10 ticks later, be suspicious
  ;let nearbys other turtles-on neighbors4 - turns out that the follower is too far away
  ; trying to implement that followers are on the patches behind?
  let nearbys min-one-of other turtles-on patch-ahead -1 [distance myself]
  ;set follower min-one-of nearbys [distance myself]; identify the agent that is nearest
  set follower nearbys
  
  if not ((follower = nobody) or (follower = self))
  [
    ; test if the same agent follows under 10 ticks
    
    ifelse countTicks > 0 
    [
      ;test runs
      ; count how many times the oldfollower was detected
      if (follower = oldfollower) [ set nr nr + 1]
      
      ; test if 10 ticks have passed
      if (ticks > countTicks + 10)
      [
      ;              
        ;compare if the same follower has appeared at least 5 times
        if (nr > 4)
        [
        ; indication for a follower
        if Debug [print (word self ": is being followed by " oldfollower)]
        
        set state "State_identifyFollower"
        ]
        ;reset the test
        set countTicks 0 ; resetting the counters
        set nr 0
        
      ]
    ]
    [;else countTicks = 0, initialize
      set oldFollower follower ; save the follower to compare with
      set nr 0
      set countTicks ticks
      if Debug [print (word self ": has possible follower: " follower)]
    ]
  ]
  
          
end

to State_IdentifyFollower
  ;stops and stands still to see if the same follower remains close by
  set color red
  ; we suspect a specific follower and only need to verify that it is nearby
  let nearbys other turtles in-radius 1
  ; checking for three ticks
  ifelse nr > 3 [
    set state "State_MoveAround" ; default next state
    set nr 0
    ; check if follower was found 3 times
    if (identNr = 3)[
      ;definitive a follower
      if Debug [print (word self " has decided to escape from follower: " follower)]
      set state "State_Escape"
    ]
    set identNr 0
  ]
  [; else nr <=3
    ;check if follower is nearby
    if (member? follower nearbys) [set identNr IdentNr + 1]; increase the counter everytime the follower is seen
    ; increase nr
    set nr nr + 1
  ]
  
end

to State_Escape
; a follower has been identified from which the agent tries to escape by moving into the zone 'sanctuary'
  set color orange
  ; move towards 'sanctuary' until it arrives
  ifelse (region = "sanctuary") 
  [
    ;arrived at sanctuary
    ;if Debug []
    set state "State_Sanctuary"
  ]
  [;else not yet at sanctuary
    let destination min-one-of patches with [region = "sanctuary"] [distance myself]
    set heading (towards destination) ;face in direction of the sanctuary-patch
    fd 2; run faster thant the followers
  ]
end

to State_Sanctuary
  set color blue
  ; move around in the sanctuary-zone
  let footstep neighborhood with [region = "sanctuary"] 
    if any? footstep [move-to one-of footstep]

end


