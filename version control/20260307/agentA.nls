; LOCAL VARIABLES
agentAs-own [
  ; some examples of possible local variables, -replace with your own
  
  nearbyAgents;---List of the agents nearby
  vision;---------how long nearby is defined as
  fmax;-----------maximum members of friends
  friend;---------potential friend to add or follow
  followFriend;---selected friend to follow
  friendList;-----agent set of other citizen agents that are considered as friends
  friends;--------list with numbers of agents (same as friendList, but as a sorted list)
  
  moveFlag;-------Flag to indicate the situation of moving freely around
  followFlag;-----Flag to indicate the situation of following a friend
  
  
  homeLoc;------------home location, where the agent lives
  localxy;------------current local patch on which the agent is standing on
  destinationxy;------destination patch to go to
  destinationRegion;-destination region to go to
  
  
 
  proState ;----------State variable for the proactive states. Enumeration = Study, 
                      ;Work, Unemployed, ’Walking around’, ’Meeting friends’, ’Go out’, Political, Resignation, Demonstration
                      ;Pursue of Happiness Goals
  vWalk ;-------------Value for Walk-desire [0..1]
  minWalk ;-----------Min-value for Walk-desire after fulfillment of desire
  thrWalk ;-----------Threshold for Walk-desire
  dWalk ;-------------Increase of vWalk for every day in percentage
  
  ;different help-variables
  counter; -----------general purpose counter
  finishedState;------indicates that a state is fulfilled and a new one can be deliberated
  initialCondition;---flag to indicate if the initial condition is met
  finalCondition; ----flag to indicate if the final condition is met
  safespot;---------- indicates if the current spot is save (not empty and not TownSquare)
  agTimer1;---------- local timer for agents
  TimerX
  agAlarm1;
  deliberationFlag;---flag to restrict one deliberation per evening/weekend
  ; Activation of test cases
  ;activateTestCase
]
;******************* end local variables *****************************************************************************************************************
;**********************************************************************************************************************************************************
; SETUP FUNCTIONS
to setup-agentAs
  ; example of create-agent-function, replace with your own code!
  
  ; override or extend this setup section with testcases
  create-agentAs Number_AgentA [; Number_AgentA from slider
      set label who
      set shape "person" 
      set size 1
      set color white
      move-to one-of patches with [region = "house"]
      ; save the home location
      set homeLoc patch-here
      ;setxy [pxcor] of homeLoc [pycor] of homeLoc 
      set friend []
      set followFriend []
      set friendList turtle-set []
      set vision 2
      set fmax 7
      ; initial values of flags
      set followFlag false 
      set moveFlag true
    
    
      
      set destinationxy []
    ]
    
end ;setup-agentAs


;***************************end setup functions ******************************************************************************************************************
;************************************************************************************************************************************************************
; UPDATE information about the agent's environment

to updateEnvironmentInfo_agentAs 
  ; add your own code here instead
  
  ; reset the flags and the variables
  ;set moveFlag true
  ;set followFlag false
  set friend []
  ;set friendList turtle-set friendList
  
  
  ; update information about other agents nearby
  set nearbyAgents other turtles in-radius vision
  ;print count nearbyAgents
  if any? nearbyAgents [
    set friend min-one-of nearbyAgents [distance myself]; identify the agent that is nearest
    ; make sure friend is not the agent itself
    if not (friend = self) [; only bother if it is not myself
                            ; if the list of friends is empty, add the agent
      ifelse (not any? turtle-set friendList) [set friendList friend]
      ;ifelse (empty? friendList) [set friendList friend]
      [
        ; if not already following a friend and member of the list of friends and less than fmax friends - add to the list of friends
        ;ifelse (length friendList < fmax) 
        if (not followFlag) [; not already following a friend
          ifelse (count turtle-set friendList < fmax) 
          [
            ;add the friend to the friendList
            ;set friendList lput friend friendList
            set friendList (turtle-set friend friendList)
            set friends sort friendList
            set moveFlag true ; flag to indicate the case of free moving around      
          ]
          [; case in which fmax of friends in friendlist
           ; check if the friend is in the friendList, if yes follow that agent
            ifelse (member? friend friendList)
            [; is member, follow it
              set followFlag true
              set moveFlag false
              set followFriend friend
              ;if Debug [print (word "friend: " friend "friends: " friends)]
            ]
            [; not a member, do not follow
              set moveFlag true
              set followFlag false
            ]
          ]
        ]  
      ]
    ]  
  ]
  
  ;--- save local position
  set localxy patch-here
  ;print (word "agentA with id: " who " has updated its beliefs")

end ;updateEnvironmentInfo_agentAs
;***************************end update environment information ******************************************************************************************************************
;************************************************************************************************************************************************************
; REACTIVE SUBSUMPTION HIERARCHY
to reactive_agentAs
  ; override updateEnvironmentInfo_agentAs by testcase-procedure
   if activateTestCase [override_agentASetup]   
  
  ; highest priority: move freely around
  ifelse moveFlag [ moveAround_agentA]
  [ifelse followFlag [followAgent]
    [; unknown case, print message
      if Debug [print (word "agentA with id: " who " is not walking around and not following a friend")]
    ]
  ]
end ;reactive_agentAs

;---- specific reactive intention functions
to moveAround_agentA
  rt random 50
  lt random 50
  fd 1
  ; make sure the agent moves to empty region within its neighborhood
  if not (region = "empty" or region = "sanctuary") [
    let footstep neighborhood with [region = "empty"] 
    if any? footstep [move-to one-of footstep]]
end

to followAgent
  if (([list xcor ycor] of self) != ([list xcor ycor] of followFriend)) [; avoids error of not being able to use heading on same position
    set heading (towards followFriend) ;face in direction of the friend-problem if on same patch
    fd 1
    if Debug [print (word "agentA with id: " who " is following a friend with id: " followFriend)]
    ; break the connection if in 'sanctuary'
    if (region = "sanctuary") [
      ;set the agent somwhere else and let it move freely again
      let places neighborhood with [region = "empty"]
      if any? places [move-to one-of places]
      set followFlag false
      set moveFlag true
      set followFriend []
      if Debug [print (word "agentA with id: " who " is being replaced away from 'sanctuary'")]
    ]
  ] 
end

to moveToDestxy_agentA
  ifelse localxy != destinationxy [
        face destinationxy
        fd 1
  ] 
  [ let reg []
    ask patch-here [set reg region]
    ;print (word who " arrived at destination: " reg)
  ]
end ;moveToDestxy
;***************************end reactive subsumption hierarchy ***************************************************************************************************
