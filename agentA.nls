; ********************************************************************************************************************************************************
;***          AGENTA.NLS  (Influencer Agent - Reactive Decision-Making Based on Attention Dynamics)                                            ****
;*********************************************************************************************************************************************************
; DESCRIPTION OF THE AGENT (REACTIVE ARCHITECTURE)
; - An influencer agent that competes for follower attention in a social media ecosystem
; - Makes reactive decisions based on follower count and engagement levels
; - Creates conflicts when losing followers or engagement to regain attention
; - Conflicts affect reputation, which in turn affects follower loyalty and retention
; - Uses reactive rules: sense engagement/followers → detect trends → create conflict if needed
;
;*********************************************************************************************************************************************************
; LOGBOOK OF UPDATES IN THIS FILE
; --Date--- |-----Description--------------------------------------------------------------------------------|---Person(s)-------------------------------
; 20260410    Implemented as influencer agent with attention-driven conflict creation                          Maximilian och Ivan
; 20260307    Initial template provided                                                                        Gion
;
;********************end logbook ************************************************************************************************************************
;*********************************************************************************************************************************************************
; LOCAL VARIABLES (INFLUENCER STATE)
agentAs-own [
  ; Perception and status variables
  followerCount        ; current number of followers (agentB) following this influencer
  engagementRadius     ; radius representing area of influence/engagement
  engagementLevel      ; current engagement (followers in perception radius)
  
  ; Reputation and history tracking
  reputation           ; trust score (0-100), affects follower loyalty
  followerHistory      ; list tracking recent follower counts for trend detection
  engagementHistory    ; list tracking recent engagement levels
  
  ; Conflict state
  conflictActive       ; boolean: currently in conflict state?
  conflictIntensity    ; current intensity of conflict (0-100)
  conflictDuration     ; ticks remaining in active conflict
  
  ; Decision thresholds
  minEngagementThreshold    ; minimum acceptable engagement level
  followerLossThreshold     ; rate of follower loss that triggers conflict
  reputationDamagePerConflict ; reputation points lost per conflict
  
  ticksSinceStableFollowing
  followerLossRate
  
  ; Movement variables
  moveSpeed            ; base speed of movement
  targetX              ; x coordinate of movement target
  targetY              ; y coordinate of movement target
  
  
  influencerColor      ; permanent unique color for each influencer
]
;******************* end local variables *****************************************************************************************************************

;**********************************************************************************************************************************************************
; SETUP FUNCTIONS

to setup-agentAs
  create-agentAs Number_AgentA [
    set label who
    set shape "star"
    set size 2
    set color yellow
    
    
    set influencerColor (5 + ((who * 10) mod 130))
    set color influencerColor
    
    ; Initialize influencer state
    set followerCount 0              ; will count follower agents in setup
    set engagementRadius 20          ; perception radius for engagement
    set engagementLevel 0
    
    ; Initialize reputation system
    set reputation 80                ; start with moderate-to-high reputation
    set followerHistory []           ; empty history at start
    set engagementHistory []
    
    ; Initialize conflict state
    set conflictActive false
    set conflictIntensity 0
    set conflictDuration 0
    
    ; Set decision thresholds
    set minEngagementThreshold 3     ; minimum followers within radius
    set followerLossThreshold 0.1    ; lose >10% triggers conflict
    set reputationDamagePerConflict 15
    
    set followerLossRate 0
    set ticksSinceStableFollowing 0
    
    ; Initialize movement
    set moveSpeed 0.5
    set targetX random max-pxcor
    set targetY random max-pycor
    move-to patch targetX targetY
  ]
end

;***************************end setup functions ***********************************************************
;**********************************************************************************************************************************************************
; UPDATE ENVIRONMENT INFORMATION (required by main model loop)

to updateEnvironmentInfo_agentAs
  ; Placeholder for compatibility with main model loop
  ; Actual sensing happens in reactive_agentAs
end

;***************************end environment update *****************************************************

;**********************************************************************************************************************************************************
; REACTIVE SENSING: Perceive current status

to sense-environment_agentAs
  ; Count current followers (agentB agents that are following this influencer)
  ; This assumes agentB has a "following" variable pointing to their influencer
  set followerCount count agentBs with [following = myself]
  
  ; Measure engagement (followers within engagement radius)
  let myRadius engagementRadius
  set engagementLevel count agentBs with [following = myself and distance myself <= myRadius]
  
  ; Track history (keep last 5 ticks)
  set followerHistory lput followerCount followerHistory
  if length followerHistory > 5 [set followerHistory but-first followerHistory]
  
  set engagementHistory lput engagementLevel engagementHistory
  if length engagementHistory > 5 [set engagementHistory but-first engagementHistory]
  
  if length followerHistory >= 2 [
    let prev-followers item (length followerHistory - 2) followerHistory
    if prev-followers > 0 [
      set followerLossRate (prev-followers - followerCount) / prev-followers
    ]
  ]
  
   ifelse followerLossRate != 0 [
        set ticksSinceStableFollowing 0
      ]
      [
       set ticksSinceStableFollowing ticksSinceStableFollowing + 1 
      ]
  
end

;***************************end sensing *******************************************************************

;**********************************************************************************************************************************************************
; REACTIVE DECISION HIERARCHY: Apply prioritized rules

to reactive_agentAs
  ; Override by test case if needed
  if activateTestCase [override_agentASetup]
  
  ; SENSE: Update current status
  sense-environment_agentAs
  
  ; MOVE: Update position (agents can move while handling other behaviors)
  move-agentA
  
  ; REACT & ACT: Apply prioritized decision rules
  
  ; PRIORITY 1: If in active conflict, continue conflict behavior and apply reputation damage
  if conflictActive [
    execute-conflict_agentA
    update-visualization_agentA
    stop
  ]
  
  ; PRIORITY 2: Detect if engagement is critically low - trigger conflict
  if engagementLevel < minEngagementThreshold and engagementLevel > 0 [
    initiate-conflict_agentA "low-engagement"
    update-visualization_agentA 
    stop
  ]
  
  ; PRIORITY 3: Detect follower loss trend - trigger conflict
  if followerLossRate > followerLossThreshold and not conflictActive [
    initiate-conflict_agentA "follower-loss"
    update-visualization_agentA
    stop
  ]
  
  ; PRIORITY 4: Detect follower loss trend - trigger conflict
  if ticksSinceStableFollowing > 200 [
    initiate-conflict_agentA "stable following"
    update-visualization_agentA 
    stop
  ]
  
  ; PRIORITY 5: Maintain normal behavior - recover reputation if not in conflict
  maintain-status_agentA
  update-visualization_agentA
end

;***************************end reactive decision hierarchy ****************************************************

;**********************************************************************************************************************************************************
; CONFLICT MECHANICS

to initiate-conflict_agentA [conflict-reason]
  ; Start a conflict to regain attention (only if not already in conflict)
  if not conflictActive [
    set conflictActive true
    set conflictIntensity 70 + random 30          ; 70-100 intensity
    set conflictDuration 5 + random 5             ; 5-10 ticks of active conflict
    
    ; Broadcast conflict event (for observer/followers to detect)
    if Debug [print (word "Influencer " who " initiated conflict: " conflict-reason " at tick " ticks)]
  ]
end

to execute-conflict_agentA
  ; While in conflict state, reputation decays
  set reputation reputation - reputationDamagePerConflict
  if reputation < 0 [set reputation 0]
  
  ; Conflict duration decreases each tick
  set conflictDuration conflictDuration - 1
  
  ; When conflict duration ends, return to normal
  if conflictDuration <= 0 [
    set conflictActive false
    set conflictIntensity 0
  ]
end

to maintain-status_agentA
  ; Normal operations: reputation slowly recovers if not in conflict
  if reputation < 80 [
    set reputation reputation + 2
  ]
  
  ; Reputation affects follower retention (followers leave with probability based on low reputation)
  if reputation < 40 [
    let departure-chance (1 - (reputation / 100)) * 0.1
    ask agentBs with [following = myself and random-float 1 < departure-chance] [
      set following nobody
    ]
  ]
end

;***************************end conflict mechanics ************************************************************

;**********************************************************************************************************************************************************
; MOVEMENT FUNCTIONS

to move-agentA
  ifelse conflictActive [
    ; During conflict: move toward followers to regain attention + move erratically
    move-conflict-behavior
  ] [
    ; Normal behavior: move toward random targets
    move-normal-behavior
  ]
end

to move-normal-behavior
  ; Pick a new target occasionally (every 20 ticks or when close to current target)
  if ticks mod 20 = 0 or distance patch targetX targetY < 2 [
    set targetX random max-pxcor
    set targetY random max-pycor
  ]
  
  ; Move towards target
  let destination patch targetX targetY
  set heading towards destination
  forward moveSpeed
end

to move-conflict-behavior
  ; During conflict, try to move toward nearest followers to regain attention
  let nearby-followers agentBs with [following = myself and distance myself < 30]
  
  ifelse any? nearby-followers [
    ; Move toward the center of nearby followers (to regain attention)
    let nearest-follower min-one-of nearby-followers [distance myself]
    set heading towards nearest-follower
    forward moveSpeed * 1.2  ; Move faster toward followers during conflict
  ] [
    ; If no nearby followers, move toward any follower
    let any-follower one-of agentBs with [following = myself]
    if any-follower != nobody [
      set heading towards any-follower
      forward moveSpeed * 1.2
    ]
  ]
  
  ; Add erratic movement: random turns make movement less predictable
  rt random 40
  lt random 40
  forward moveSpeed * 0.5  ; Additional erratic movement
end

;***************************end movement functions **********************************************************

;**********************************************************************************************************************************************************
; ACTION EXECUTION: Visual feedback and state updates

to update-visualization_agentA
  ; Update color based on reputation
  set influencerColor (5 + ((who * 10) mod 130))
  set color influencerColor
  
  
  ;(ifelse reputation > 70 [
   ;  set color yellow
  ;] 
   ; reputation > 50 [
    ;  set color orange
  ;])
  
 
  ; Pulse size during conflict to show activity
  ifelse conflictActive [
    set color red
  ] [
    set size 2 + (followerCount / 100)
  ]
end

;***************************end action execution ************************************************************

;**********************************************************************************************************************************************************
; TEST CASE SUPPORT

to override_agentASetup
  ; Placeholder for test case overrides
  ; Can be extended to force specific conflict states for testing
end

;***************************end test case support ************************************************************

;**********************************************************************************************************************************************************
; REPORTER FUNCTIONS: Provide observable metrics for monitoring

to-report get-influencer-status
  ; Returns a list of status information: [follower-count engagement reputation conflict-active]
  report (list followerCount engagementLevel reputation conflictActive)
end

to-report get-conflict-intensity
  ; Returns current conflict intensity for visualization
  report conflictIntensity
end
;***************************end reporter functions *************************************************************
